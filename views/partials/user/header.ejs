<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Fruitables - Vegetable Website Template</title>
    <link rel="icon" type="image/png" href="/img/hero-img-1.png">
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <meta content="" name="keywords" />
    <meta content="" name="description" />
    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600&family=Raleway:wght@600;800&display=swap"
      rel="stylesheet"
    />
    <!-- Icon Font Stylesheet -->
    <link
      rel="stylesheet"
      href="https://use.fontawesome.com/releases/v5.15.4/css/all.css"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css"
      rel="stylesheet"
    />
    <!-- Libraries Stylesheet -->
    <link href="/lib/lightbox/css/lightbox.min.css" rel="stylesheet" />
    <link href="/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet" />

    <!-- Customized Bootstrap Stylesheet -->
    <link href="/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Template Stylesheet -->
    <link href="/css/style.css" rel="stylesheet" />
    
    <!-- Additional Custom Styles for Responsive Header -->
    <style>
      /* General responsive styles */
      .navbar-brand .display-6 {
        transition: font-size 0.3s ease;
      }
      
      .shop-icon {
        position: relative;
        margin-left: 15px;
        display: inline-block;
      }
      
      .shop-icon-container {
        display: flex;
        align-items: center;
      }
      
      /* Medium to large screens */
      @media (min-width: 992px) {
        .icon-container {
          margin-left: 15px;
        }
      }
      
      /* Small to medium screens */
      @media (max-width: 991.98px) {
        .navbar-collapse {
          position: absolute;
          top: 100%;
          left: 0;
          right: 0;
          background-color: white;
          padding: 15px;
          z-index: 1000;
          box-shadow: 0 4px 6px rgba(0,0,0,0.1);
          border-radius: 0 0 8px 8px;
        }
        
        .navbar-brand .display-6 {
          font-size: 1.5rem;
        }
        
        .inline-nav {
          display: flex;
          flex-direction: column !important;
          align-items: center;
          width: 100%;
        }
        
        .inline-nav .nav-item {
          margin: 5px 0;
        }
        
        .icon-container {
          display: flex;
          justify-content: center;
          margin-top: 10px;
          width: 100%;
        }
      }
      
      /* Extra small screens */
      @media (max-width: 575.98px) {
        .navbar-brand .display-6 {
          font-size: 1.2rem;
        }
        
        .navbar-toggler {
          padding: 0.25rem 0.5rem;
        }
        
        .topbar {
          font-size: 0.8rem;
        }
      }
      
      /* Back to top button position */
      .back-to-top {
        position: fixed;
        bottom: 30px;
        right: 20px;
        z-index: 99;
        opacity: 0.8;
        transition: opacity 0.3s;
      }
      
      .back-to-top:hover {
        opacity: 1;
      }
    </style>
  </head>
  <body>
   
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Header Section -->
    <div class="container-fluid fixed-top">
      <!-- Topbar -->
      <div class="container topbar bg-primary d-none d-lg-block">
        <div class="d-flex justify-content-between">
          <div class="top-info ps-2"></div>
          <div>
            <medium class="me-3">Welcome</medium>
          </div>
          <div class="top-link pe-2">
            <% if (locals.user!=null) { %>
              <%=locals.user.name %>
            <% console.log(locals.user) }%>
          </div>
        </div>
      </div>
      
      <!-- Main Navigation -->
      <div class="container px-0">
        <nav class="navbar navbar-light bg-white navbar-expand-lg py-2">
          <div class="container-fluid px-0">
            <a href="/" class="navbar-brand">
              <h1 class="text-primary display-6 m-0">Fruitables</h1>
            </a>
            
            <!-- Shopping Icons for Mobile - Visible only on mobile -->
            <div class="d-flex d-lg-none me-2">
              <a href="getWishlist" class="shop-icon">
                <i class="fa fa-heart" style="font-size: 20px; color: red"></i>
              </a>
              <a href="/getcart" class="shop-icon ms-3">
                <i class="fa fa-shopping-bag" style="font-size: 20px;"></i>
                <% if (locals.user != null && cart != null && cart.items) { %>
                  <span class="position-absolute bg-secondary rounded-circle d-flex align-items-center justify-content-center text-dark px-1" style="top: -5px; right: -5px; height: 16px; min-width: 16px; font-size: 9px;">
                    <%= cart.items.length %>
                  </span>
                <% } %>
              </a>
            </div>
            
            <button
              class="navbar-toggler"
              type="button"
              data-bs-toggle="collapse"
              data-bs-target="#navbarCollapse"
            >
              <span class="fa fa-bars text-primary"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarCollapse">
              <!-- Navigation Links -->
              <div class="navbar-nav mx-auto inline-nav">
                <a href="/home" class="nav-item nav-link active">Home</a>
                <a href="/shop" class="nav-item nav-link">Shop</a>
                
                <% if (locals.user != null) { %>
                  <a href="/userProfile/<%= user._id %>" class="nav-item nav-link">Profile</a>
                  <a href="/logout" class="nav-item nav-link">Logout</a>
                <% } else { %>
                  <a href="/login" class="nav-item nav-link">Login</a>
                  <a href="/signup" class="nav-item nav-link">Sign up</a>
                <% } %>
              </div>
              
              <!-- Shopping Icons for Desktop - Visible only on desktop -->
              <div class="d-none d-lg-flex icon-container">
                <a href="getWishlist" class="shop-icon">
                  <i class="fa fa-heart" style="font-size: 24px; color: red"></i>
                </a>
                <a href="/getcart" class="shop-icon ms-3">
                  <i class="fa fa-shopping-bag" style="font-size: 24px;"></i>
                  <% if (locals.user != null && cart != null && cart.items) { %>
                    <span class="position-absolute bg-secondary rounded-circle d-flex align-items-center justify-content-center text-dark px-1" style="top: -5px; right: -5px; height: 18px; min-width: 18px; font-size: 10px;">
                      <%= cart.items.length %>
                    </span>
                  <% } %>
                </a>
              </div>
            </div>
          </div>
        </nav>
      </div>
    </div>
    
    <!-- Back to Top -->
    <a href="#" class="btn btn-primary border-3 border-primary rounded-circle back-to-top"><i class="fa fa-arrow-up"></i></a>
  </body>
</html>